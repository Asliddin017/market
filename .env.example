# ---------------------------------------------------------------------------
# ASL_ZIYO environment variables
#
# Copy this file to `.env.local` and fill in the values from your Supabase
# project (Project Settings -> API). Add the SAME two VITE_* values to your
# Vercel project (Settings -> Environment Variables) before deploying.
# ---------------------------------------------------------------------------

# Frontend (safe to expose — protected by Row Level Security).
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Seeding ONLY (Node script scripts/seed.js). NEVER expose this in the frontend
# or commit it. It bypasses Row Level Security. Do NOT add this to Vercel.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
